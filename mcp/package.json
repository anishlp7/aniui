{
  "name": "@aniui/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "AniUI MCP server — expose component registry, theme tokens, and code examples to AI tools",
  "license": "MIT",
  "author": "Anish",
  "repository": {
    "type": "git",
    "url": "https://github.com/anishlp7/aniui",
    "directory": "mcp"
  },
  "homepage": "https://aniui.dev",
  "bugs": "https://github.com/anishlp7/aniui/issues",
  "main": "dist/index.js",
  "bin": {
    "aniui-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "components",
    "lib",
    "templates"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "rm -rf components lib templates && cp -r ../components . && cp -r ../lib . && cp -r ../templates .",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^6.0.2"
  }
}
