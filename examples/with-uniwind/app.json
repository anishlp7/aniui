{
  "expo": {
    "name": "aniui-uniwind",
    "slug": "aniui-uniwind",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aniui-uniwind",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
